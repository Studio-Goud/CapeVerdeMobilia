{
  "name": "ilhavista",
  "version": "0.1.0",
  "private": true,
  "description": "Ilhavista — independent digital infrastructure for property, building and public information in Cabo Verde.",
  "license": "MIT",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @ilhavista/database generate",
    "db:migrate": "pnpm --filter @ilhavista/database migrate",
    "db:seed": "pnpm --filter @ilhavista/database seed",
    "db:reset": "pnpm --filter @ilhavista/database reset"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.0.9",
    "typescript": "^5.5.4"
  }
}
