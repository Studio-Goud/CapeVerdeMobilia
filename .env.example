# =========================================================================
# Kavíla — environment variables (copy to .env and fill in). NEVER commit .env
# =========================================================================

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# --- Database (PostgreSQL + PostGIS) ---
# Local docker-compose default:
DATABASE_URL=postgresql://kavila:kavila@localhost:5432/kavila?schema=public
# Prisma shadow db for migrations (optional in dev)
SHADOW_DATABASE_URL=postgresql://kavila:kavila@localhost:5432/kavila_shadow?schema=public

# --- Redis (cache / queues / rate limiting) ---
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# 32+ char random string. Generate: openssl rand -base64 48
AUTH_SECRET=replace-me-with-a-long-random-secret
SESSION_TTL_HOURS=168
OTP_TTL_MINUTES=10
# MFA
MFA_ISSUER=Kavila

# --- Email provider (transactional) ---
EMAIL_FROM="Kavíla <no-reply@kavila.cv>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- WhatsApp (MVP: click-to-chat deep links; later: Business API) ---
WHATSAPP_SUPPORT_NUMBER=2389000000
WHATSAPP_BUSINESS_API_TOKEN=

# --- Object storage (S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=kavila-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=http://localhost:9000/kavila-media

# --- Search (MVP uses Postgres FTS; Meilisearch optional/later) ---
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# --- Maps (map tiles / geocoding provider) ---
MAP_TILES_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# --- Payments (later phase; disabled in MVP) ---
PAYMENTS_ENABLED=false
PAYMENT_PROVIDER=
PAYMENT_API_KEY=

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=

# --- i18n ---
DEFAULT_LOCALE=pt
SUPPORTED_LOCALES=pt,kea,en,nl,fr

# --- Machine translation (optional; official texts never auto-overwritten) ---
TRANSLATION_PROVIDER=
TRANSLATION_API_KEY=
