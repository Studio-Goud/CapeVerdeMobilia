# Djarvista — environment variables
#
# Leave these EMPTY to run the site in demo mode (fictional data, local login).
# Fill them in to switch the whole app to the real Supabase backend.
#
# Get both values in your Supabase project: Settings → API
#   - Project URL          -> NEXT_PUBLIC_SUPABASE_URL
#   - Project API keys: anon public -> NEXT_PUBLIC_SUPABASE_ANON_KEY

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Analytics 4 — live visitor tracking. Create a GA4 property, copy its
# Measurement ID (G-XXXXXXXXXX) and set it here (and in Vercel → Project →
# Settings → Environment Variables). Then GA4 → Reports → Realtime shows live
# visitors. Leave empty to disable. Vercel Web Analytics also runs automatically.
NEXT_PUBLIC_GA_ID=
